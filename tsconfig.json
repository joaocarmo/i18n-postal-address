{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals"],
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext"
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "dist/**/*"]
}
