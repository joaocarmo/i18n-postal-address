{
  "name": "i18n-postal-address",
  "version": "0.10.0",
  "description": "A JavaScript library to produce international postal addresses formatted by region for node and the web",
  "homepage": "https://joaocarmo.com/i18n-postal-address-playground",
  "author": "João Carmo",
  "license": "MIT",
  "browser": "./dist/postal-address.js",
  "main": "./dist/postal-address.node.js",
  "exports": {
    ".": {
      "import": "./dist/postal-address.js",
      "browser": "./dist/postal-address.js",
      "require": "./dist/postal-address.node.js"
    },
    "./strings": {
      "require": "./dist/postal-address.strings.node.js"
    }
  },
  "types": "./dist/index.d.ts",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:types": "tsc -p tsconfig.declaration.json",
    "build": "NODE_ENV=production webpack",
    "clean": "rm -rf ./dist/ && rm -rf ./node_modules/.cache/",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prepare": "husky",
    "pretty:fix": "prettier --write .",
    "pretty": "prettier --check .",
    "test:functional:strings": "./test-functional/test-strings.js",
    "test:functional": "./test-functional/test.js",
    "test:unit": "jest",
    "test": "jest",
    "type-check:watch": "pnpm type-check -- --watch",
    "type-check": "tsc --noEmit",
    "formats:fetch": "tsx scripts/fetch-google-formats.ts",
    "formats:transform": "tsx scripts/transform-google-formats.ts",
    "formats:diff": "tsx scripts/diff-formats.ts",
    "formats:update": "tsx scripts/fetch-google-formats.ts && tsx scripts/transform-google-formats.ts && tsx scripts/diff-formats.ts"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaocarmo/i18n-postal-address.git"
  },
  "bugs": {
    "url": "https://github.com/joaocarmo/i18n-postal-address/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "tag": "latest"
  },
  "keywords": [
    "address",
    "formatter",
    "i18n",
    "node",
    "postal",
    "web"
  ],
  "optionalDependencies": {
    "node-postal": "^1.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/node-postal": "^1.1.3",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.1.1",
    "core-js": "^3.49.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.3",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "node-postal": "^1.3.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
