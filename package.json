{
  "name": "i18n-postal-address",
  "version": "0.10.0",
  "description": "A JavaScript library to produce international postal addresses formatted by region for node and the web",
  "homepage": "https://joaocarmo.com/i18n-postal-address-playground",
  "author": "João Carmo",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./formats": {
      "types": "./dist/formats/index.d.ts",
      "import": "./dist/formats/index.js"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf ./dist/",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prepare": "husky",
    "pretty:fix": "prettier --write .",
    "pretty": "prettier --check .",
    "test:functional": "node test-functional/test.js",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test": "vitest run",
    "type-check:watch": "pnpm type-check -- --watch",
    "type-check": "tsc --noEmit",
    "formats:fetch": "tsx scripts/fetch-google-formats.ts",
    "formats:transform": "tsx scripts/transform-google-formats.ts",
    "formats:diff": "tsx scripts/diff-formats.ts",
    "formats:update": "tsx scripts/fetch-google-formats.ts && tsx scripts/transform-google-formats.ts && tsx scripts/diff-formats.ts"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaocarmo/i18n-postal-address.git"
  },
  "bugs": {
    "url": "https://github.com/joaocarmo/i18n-postal-address/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "tag": "latest"
  },
  "keywords": [
    "address",
    "formatter",
    "i18n",
    "node",
    "postal",
    "web"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
